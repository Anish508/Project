<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.alumni.connect.ui.home.HomeFragment"
        android:label="Home Feed"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_directory"
        android:name="com.alumni.connect.ui.directory.DirectoryFragment"
        android:label="Directory"
        tools:layout="@layout/fragment_directory">
        <action
            android:id="@+id/action_directory_to_detail"
            app:destination="@id/nav_alumni_detail" />
    </fragment>

    <fragment
        android:id="@+id/nav_alumni_detail"
        android:name="com.alumni.connect.ui.directory.AlumniDetailFragment"
        android:label="Alumni Profile"
        tools:layout="@layout/fragment_alumni_detail" />

    <fragment
        android:id="@+id/nav_jobs"
        android:name="com.alumni.connect.ui.jobs.JobsFragment"
        android:label="Job Portal"
        tools:layout="@layout/fragment_jobs">
        <action
            android:id="@+id/action_jobs_to_create"
            app:destination="@id/nav_create_job" />
    </fragment>

    <fragment
        android:id="@+id/nav_create_job"
        android:name="com.alumni.connect.ui.jobs.CreateJobFragment"
        android:label="Post Job"
        tools:layout="@layout/fragment_create_job" />

    <fragment
        android:id="@+id/nav_mentorship"
        android:name="com.alumni.connect.ui.mentorship.MentorshipFragment"
        android:label="Mentorship &amp; Events"
        tools:layout="@layout/fragment_mentorship" />

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.alumni.connect.ui.profile.ProfileFragment"
        android:label="My Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_edit"
            app:destination="@id/nav_edit_profile" />
    </fragment>

    <fragment
        android:id="@+id/nav_edit_profile"
        android:name="com.alumni.connect.ui.profile.EditProfileFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_edit_profile" />

    <fragment
        android:id="@+id/nav_admin"
        android:name="com.alumni.connect.ui.admin.AdminDashboardFragment"
        android:label="Admin Dashboard"
        tools:layout="@layout/fragment_admin_dashboard" />
</navigation>
